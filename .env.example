# Optional: API keys can also be configured in the Settings page at http://localhost:3000/settings
# If set here, they act as defaults. Keys saved in Settings take priority.

# Twitch API — get from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Google Gemini API — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# App URL (no need to change for local development)
NEXT_PUBLIC_APP_URL=http://localhost:3000
